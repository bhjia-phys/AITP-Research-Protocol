{
  "mcpServers": {
    "aitp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--with",
        "pyyaml",
        "--with",
        "jsonschema",
        "--with",
        "fastmcp",
        "python",
        "scripts/launch_aitp_mcp.py"
      ],
      "cwd": ".",
      "startup_timeout_sec": 60
    }
  }
}
