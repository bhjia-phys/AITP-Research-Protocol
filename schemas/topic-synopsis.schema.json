{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aitp.dev/schemas/topic-synopsis.schema.json",
  "title": "TopicSynopsis",
  "description": "Lightweight agent-facing synopsis for the active topic. Used to keep ordinary AITP topic work in a low-context profile.",
  "type": "object",
  "required": [
    "id",
    "topic_slug",
    "title",
    "question",
    "lane",
    "load_profile",
    "status",
    "l1_source_intake",
    "runtime_focus",
    "truth_sources",
    "next_action_summary",
    "open_gap_summary",
    "pending_decision_count",
    "knowledge_packet_paths",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^topic_synopsis:[a-z0-9-]+$"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "formal_theory",
        "toy_numeric",
        "code_method"
      ]
    },
    "load_profile": {
      "type": "string",
      "enum": [
        "light",
        "full"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "human_request": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "l1_source_intake": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_count",
        "assumption_rows",
        "regime_rows",
        "reading_depth_rows"
      ],
      "properties": {
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "assumption_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "assumption",
              "reading_depth",
              "evidence_excerpt"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "assumption": {
                "type": "string",
                "minLength": 1
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "evidence_excerpt": {
                "type": "string"
              }
            }
          }
        },
        "regime_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "regime",
              "reading_depth",
              "evidence_excerpt"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "regime": {
                "type": "string",
                "minLength": 1
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "evidence_excerpt": {
                "type": "string"
              }
            }
          }
        },
        "reading_depth_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "reading_depth",
              "basis"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "basis": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "runtime_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "why_this_topic_is_here",
        "resume_stage",
        "last_materialized_stage",
        "next_action_id",
        "next_action_type",
        "next_action_summary",
        "human_need_status",
        "human_need_kind",
        "human_need_summary",
        "blocker_summary",
        "last_evidence_kind",
        "last_evidence_summary",
        "dependency_status",
        "dependency_summary",
        "promotion_status"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "why_this_topic_is_here": {
          "type": "string",
          "minLength": 1
        },
        "resume_stage": {
          "type": "string"
        },
        "last_materialized_stage": {
          "type": "string"
        },
        "next_action_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action_summary": {
          "type": "string",
          "minLength": 1
        },
        "human_need_status": {
          "type": "string",
          "minLength": 1
        },
        "human_need_kind": {
          "type": "string",
          "minLength": 1
        },
        "human_need_summary": {
          "type": "string",
          "minLength": 1
        },
        "blocker_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last_evidence_kind": {
          "type": "string",
          "minLength": 1
        },
        "last_evidence_summary": {
          "type": "string",
          "minLength": 1
        },
        "dependency_status": {
          "type": "string",
          "minLength": 1
        },
        "dependency_summary": {
          "type": "string",
          "minLength": 1
        },
        "promotion_status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "truth_sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic_state_path",
        "research_question_contract_path",
        "next_action_surface_path",
        "human_need_surface_path",
        "dependency_registry_path",
        "promotion_readiness_path",
        "promotion_gate_path"
      ],
      "properties": {
        "topic_state_path": {
          "type": "string",
          "minLength": 1
        },
        "research_question_contract_path": {
          "type": "string",
          "minLength": 1
        },
        "next_action_surface_path": {
          "type": "string",
          "minLength": 1
        },
        "human_need_surface_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "dependency_registry_path": {
          "type": "string",
          "minLength": 1
        },
        "promotion_readiness_path": {
          "type": "string",
          "minLength": 1
        },
        "promotion_gate_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "next_action_summary": {
      "type": "string",
      "minLength": 1
    },
    "open_gap_summary": {
      "type": "string",
      "minLength": 1
    },
    "pending_decision_count": {
      "type": "integer",
      "minimum": 0
    },
    "knowledge_packet_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
