{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aitp.dev/schemas/topic-synopsis.schema.json",
  "title": "TopicSynopsis",
  "description": "Lightweight agent-facing synopsis for the active topic. Used to keep ordinary AITP topic work in a low-context profile.",
  "type": "object",
  "required": [
    "id",
    "topic_slug",
    "title",
    "question",
    "lane",
    "load_profile",
    "status",
    "l1_source_intake",
    "runtime_focus",
    "truth_sources",
    "next_action_summary",
    "open_gap_summary",
    "pending_decision_count",
    "knowledge_packet_paths",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^topic_synopsis:[a-z0-9-]+$"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "lane": {
      "type": "string",
      "enum": [
        "formal_theory",
        "toy_numeric",
        "code_method"
      ]
    },
    "load_profile": {
      "type": "string",
      "enum": [
        "light",
        "full"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "human_request": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "l1_source_intake": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_count",
        "assumption_rows",
        "regime_rows",
        "reading_depth_rows",
        "method_specificity_rows"
      ],
      "properties": {
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "assumption_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "assumption",
              "reading_depth",
              "evidence_excerpt"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "assumption": {
                "type": "string",
                "minLength": 1
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "evidence_excerpt": {
                "type": "string"
              }
            }
          }
        },
        "regime_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "regime",
              "reading_depth",
              "evidence_excerpt"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "regime": {
                "type": "string",
                "minLength": 1
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "evidence_excerpt": {
                "type": "string"
              }
            }
          }
        },
        "reading_depth_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "reading_depth",
              "basis"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "basis": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "method_specificity_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "method_family",
              "specificity_tier",
              "reading_depth",
              "evidence_excerpt"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "method_family": {
                "type": "string",
                "minLength": 1
              },
              "specificity_tier": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "evidence_excerpt": {
                "type": "string"
              }
            }
          }
        },
        "notation_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "symbol",
              "meaning",
              "reading_depth",
              "evidence_excerpt"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "symbol": {
                "type": "string",
                "minLength": 1
              },
              "meaning": {
                "type": "string",
                "minLength": 1
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "evidence_excerpt": {
                "type": "string"
              }
            }
          }
        },
        "contradiction_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "source_id",
              "source_title",
              "source_type",
              "reading_depth",
              "against_source_id",
              "against_source_title",
              "against_source_type",
              "against_reading_depth",
              "detail",
              "comparison_basis",
              "source_basis_type",
              "source_basis_summary",
              "source_evidence_excerpt",
              "against_basis_type",
              "against_basis_summary",
              "against_evidence_excerpt"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "against_source_id": {
                "type": "string",
                "minLength": 1
              },
              "against_source_title": {
                "type": "string"
              },
              "against_source_type": {
                "type": "string"
              },
              "against_reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "detail": {
                "type": "string",
                "minLength": 1
              },
              "comparison_basis": {
                "type": "string",
                "minLength": 1
              },
              "source_basis_type": {
                "type": "string",
                "minLength": 1
              },
              "source_basis_summary": {
                "type": "string",
                "minLength": 1
              },
              "source_evidence_excerpt": {
                "type": "string",
                "minLength": 1
              },
              "against_basis_type": {
                "type": "string",
                "minLength": 1
              },
              "against_basis_summary": {
                "type": "string",
                "minLength": 1
              },
              "against_evidence_excerpt": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notation_tension_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "reading_depth",
              "against_source_id",
              "against_source_title",
              "against_source_type",
              "against_reading_depth",
              "meaning",
              "existing_symbol",
              "incoming_symbol"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "minLength": 1
              },
              "source_title": {
                "type": "string"
              },
              "source_type": {
                "type": "string"
              },
              "reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "against_source_id": {
                "type": "string",
                "minLength": 1
              },
              "against_source_title": {
                "type": "string"
              },
              "against_source_type": {
                "type": "string"
              },
              "against_reading_depth": {
                "type": "string",
                "enum": [
                  "full_read",
                  "abstract_only",
                  "skim"
                ]
              },
              "meaning": {
                "type": "string",
                "minLength": 1
              },
              "existing_symbol": {
                "type": "string",
                "minLength": 1
              },
              "incoming_symbol": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "concept_graph": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "nodes",
            "edges",
            "hyperedges",
            "communities",
            "god_nodes"
          ],
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "source_id",
                  "node_id",
                  "label",
                  "node_type",
                  "confidence_tier",
                  "confidence_score"
                ],
                "properties": {
                  "source_id": { "type": "string", "minLength": 1 },
                  "source_title": { "type": "string" },
                  "source_type": { "type": "string" },
                  "node_id": { "type": "string", "minLength": 1 },
                  "label": { "type": "string", "minLength": 1 },
                  "node_type": { "type": "string", "minLength": 1 },
                  "confidence_tier": { "type": "string", "minLength": 1 },
                  "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_id", "edge_id", "from_id", "relation", "to_id"],
                "properties": {
                  "source_id": { "type": "string", "minLength": 1 },
                  "edge_id": { "type": "string", "minLength": 1 },
                  "from_id": { "type": "string", "minLength": 1 },
                  "relation": { "type": "string", "minLength": 1 },
                  "to_id": { "type": "string", "minLength": 1 }
                }
              }
            },
            "hyperedges": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_id", "hyperedge_id", "relation", "node_ids"],
                "properties": {
                  "source_id": { "type": "string", "minLength": 1 },
                  "hyperedge_id": { "type": "string", "minLength": 1 },
                  "relation": { "type": "string", "minLength": 1 },
                  "node_ids": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            "communities": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_id", "community_id", "label", "node_ids"],
                "properties": {
                  "source_id": { "type": "string", "minLength": 1 },
                  "community_id": { "type": "string", "minLength": 1 },
                  "label": { "type": "string", "minLength": 1 },
                  "node_ids": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            },
            "god_nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["source_id", "node_id", "label"],
                "properties": {
                  "source_id": { "type": "string", "minLength": 1 },
                  "node_id": { "type": "string", "minLength": 1 },
                  "label": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "runtime_focus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "why_this_topic_is_here",
        "resume_stage",
        "last_materialized_stage",
        "next_action_id",
        "next_action_type",
        "next_action_summary",
        "human_need_status",
        "human_need_kind",
        "human_need_summary",
        "blocker_summary",
        "last_evidence_kind",
        "last_evidence_summary",
        "dependency_status",
        "dependency_summary",
        "promotion_status",
        "momentum_status",
        "stuckness_status",
        "surprise_status",
        "judgment_summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "why_this_topic_is_here": {
          "type": "string",
          "minLength": 1
        },
        "resume_stage": {
          "type": "string"
        },
        "last_materialized_stage": {
          "type": "string"
        },
        "next_action_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_action_summary": {
          "type": "string",
          "minLength": 1
        },
        "human_need_status": {
          "type": "string",
          "minLength": 1
        },
        "human_need_kind": {
          "type": "string",
          "minLength": 1
        },
        "human_need_summary": {
          "type": "string",
          "minLength": 1
        },
        "blocker_summary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last_evidence_kind": {
          "type": "string",
          "minLength": 1
        },
        "last_evidence_summary": {
          "type": "string",
          "minLength": 1
        },
        "dependency_status": {
          "type": "string",
          "minLength": 1
        },
        "dependency_summary": {
          "type": "string",
          "minLength": 1
        },
        "promotion_status": {
          "type": "string",
          "minLength": 1
        },
        "momentum_status": {
          "type": "string",
          "minLength": 1
        },
        "stuckness_status": {
          "type": "string",
          "minLength": 1
        },
        "surprise_status": {
          "type": "string",
          "minLength": 1
        },
        "judgment_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "truth_sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "topic_state_path",
        "research_question_contract_path",
        "next_action_surface_path",
        "human_need_surface_path",
        "dependency_registry_path",
        "promotion_readiness_path",
        "promotion_gate_path"
      ],
      "properties": {
        "topic_state_path": {
          "type": "string",
          "minLength": 1
        },
        "research_question_contract_path": {
          "type": "string",
          "minLength": 1
        },
        "next_action_surface_path": {
          "type": "string",
          "minLength": 1
        },
        "human_need_surface_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "dependency_registry_path": {
          "type": "string",
          "minLength": 1
        },
        "promotion_readiness_path": {
          "type": "string",
          "minLength": 1
        },
        "promotion_gate_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "next_action_summary": {
      "type": "string",
      "minLength": 1
    },
    "open_gap_summary": {
      "type": "string",
      "minLength": 1
    },
    "pending_decision_count": {
      "type": "integer",
      "minimum": 0
    },
    "knowledge_packet_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
