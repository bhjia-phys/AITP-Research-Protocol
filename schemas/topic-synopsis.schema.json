{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aitp.dev/schemas/topic-synopsis.schema.json",
  "title": "TopicSynopsis",
  "description": "Lightweight agent-facing synopsis for the active topic. Used to keep ordinary AITP topic work in a low-context profile.",
  "type": "object",
  "required": [
    "id",
    "topic_slug",
    "title",
    "question",
    "task_type",
    "lane",
    "load_profile",
    "status",
    "interaction_class",
    "stop_status",
    "stop_reason",
    "primary_result_shape",
    "next_action_summary",
    "open_gap_summary",
    "pending_decision_count",
    "knowledge_packet_paths",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^topic_synopsis:[a-z0-9-]+$"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "enum": [
        "open_exploration",
        "conjecture_attempt",
        "target_driven_execution"
      ]
    },
    "lane": {
      "type": "string",
      "enum": [
        "formal_theory",
        "toy_numeric",
        "first_principles",
        "theory_synthesis",
        "code_method"
      ]
    },
    "load_profile": {
      "type": "string",
      "enum": [
        "light",
        "full"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "human_request": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interaction_class": {
      "type": "string",
      "enum": [
        "free_explore",
        "silent_continue",
        "non_blocking_update",
        "checkpoint_question"
      ]
    },
    "stop_status": {
      "type": "string",
      "enum": [
        "continue",
        "checkpoint_required"
      ]
    },
    "stop_reason": {
      "type": "string"
    },
    "primary_result_shape": {
      "type": "string",
      "enum": [
        "status_update",
        "result_brief",
        "checkpoint_card"
      ]
    },
    "next_action_summary": {
      "type": "string",
      "minLength": 1
    },
    "open_gap_summary": {
      "type": "string",
      "minLength": 1
    },
    "pending_decision_count": {
      "type": "integer",
      "minimum": 0
    },
    "knowledge_packet_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
