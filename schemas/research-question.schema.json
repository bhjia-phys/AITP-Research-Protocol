{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResearchQuestionContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question_id",
    "title",
    "topic_slug",
    "status",
    "question",
    "scope",
    "assumptions",
    "non_goals",
    "target_layers"
  ],
  "properties": {
    "question_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "topic_slug": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "active", "blocked", "closed"] },
    "question": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "non_goals": { "type": "array", "items": { "type": "string" } },
    "context_intake": { "type": "array", "items": { "type": "string" } },
    "source_basis_refs": { "type": "array", "items": { "type": "string" } },
    "l1_source_intake": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_count", "assumption_rows", "regime_rows", "reading_depth_rows"],
      "properties": {
        "source_count": { "type": "integer", "minimum": 0 },
        "assumption_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "source_title", "source_type", "assumption", "reading_depth", "evidence_excerpt"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_title": { "type": "string" },
              "source_type": { "type": "string" },
              "assumption": { "type": "string", "minLength": 1 },
              "reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "evidence_excerpt": { "type": "string" },
              "evidence_sentence_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "regime_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "source_title", "source_type", "regime", "reading_depth", "evidence_excerpt"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_title": { "type": "string" },
              "source_type": { "type": "string" },
              "regime": { "type": "string", "minLength": 1 },
              "reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "evidence_excerpt": { "type": "string" },
              "evidence_sentence_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "reading_depth_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "source_title", "source_type", "reading_depth", "basis"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_title": { "type": "string" },
              "source_type": { "type": "string" },
              "reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "basis": { "type": "string", "minLength": 1 }
            }
          }
        },
        "notation_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "source_title", "source_type", "symbol", "meaning", "reading_depth", "evidence_excerpt"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_title": { "type": "string" },
              "source_type": { "type": "string" },
              "symbol": { "type": "string", "minLength": 1 },
              "meaning": { "type": "string", "minLength": 1 },
              "reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "evidence_excerpt": { "type": "string" },
              "evidence_sentence_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "contradiction_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "source_id",
              "source_title",
              "source_type",
              "reading_depth",
              "against_source_id",
              "against_source_title",
              "against_source_type",
              "against_reading_depth",
              "detail",
              "comparison_basis",
              "source_basis_type",
              "source_basis_summary",
              "source_evidence_excerpt",
              "against_basis_type",
              "against_basis_summary",
              "against_evidence_excerpt"
            ],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "source_id": { "type": "string", "minLength": 1 },
              "source_title": { "type": "string" },
              "source_type": { "type": "string" },
              "reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "against_source_id": { "type": "string", "minLength": 1 },
              "against_source_title": { "type": "string" },
              "against_source_type": { "type": "string" },
              "against_reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "detail": { "type": "string", "minLength": 1 }
              ,
              "comparison_basis": { "type": "string", "minLength": 1 },
              "source_basis_type": { "type": "string", "minLength": 1 },
              "source_basis_summary": { "type": "string", "minLength": 1 },
              "source_evidence_excerpt": { "type": "string", "minLength": 1 },
              "source_evidence_sentence_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "against_basis_type": { "type": "string", "minLength": 1 },
              "against_basis_summary": { "type": "string", "minLength": 1 },
              "against_evidence_excerpt": { "type": "string", "minLength": 1 },
              "against_evidence_sentence_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "notation_tension_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "source_title",
              "source_type",
              "reading_depth",
              "against_source_id",
              "against_source_title",
              "against_source_type",
              "against_reading_depth",
              "meaning",
              "existing_symbol",
              "incoming_symbol"
            ],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_title": { "type": "string" },
              "source_type": { "type": "string" },
              "reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "against_source_id": { "type": "string", "minLength": 1 },
              "against_source_title": { "type": "string" },
              "against_source_type": { "type": "string" },
              "against_reading_depth": { "type": "string", "enum": ["full_read", "abstract_only", "skim"] },
              "meaning": { "type": "string", "minLength": 1 },
              "existing_symbol": { "type": "string", "minLength": 1 },
              "incoming_symbol": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "l1_vault": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vault_version",
        "status",
        "topic_slug",
        "authority_level",
        "protocol_path",
        "root_path",
        "raw",
        "wiki",
        "output",
        "compatibility_refs"
      ],
      "properties": {
        "vault_version": { "type": "integer", "const": 1 },
        "status": { "type": "string", "minLength": 1 },
        "topic_slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "authority_level": { "type": "string", "minLength": 1 },
        "protocol_path": { "type": "string", "minLength": 1 },
        "root_path": { "type": "string", "minLength": 1 },
        "raw": {
          "type": "object",
          "additionalProperties": false,
          "required": ["manifest_path", "note_path", "source_count"],
          "properties": {
            "manifest_path": { "type": "string", "minLength": 1 },
            "note_path": { "type": "string", "minLength": 1 },
            "source_count": { "type": "integer", "minimum": 0 }
          }
        },
        "wiki": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schema_path", "home_page_path", "page_count", "page_paths"],
          "properties": {
            "schema_path": { "type": "string", "minLength": 1 },
            "home_page_path": { "type": "string", "minLength": 1 },
            "page_count": { "type": "integer", "minimum": 0 },
            "page_paths": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["digest_path", "digest_note_path", "flowback_log_path", "flowback_note_path", "flowback_entry_count"],
          "properties": {
            "digest_path": { "type": "string", "minLength": 1 },
            "digest_note_path": { "type": "string", "minLength": 1 },
            "flowback_log_path": { "type": "string", "minLength": 1 },
            "flowback_note_path": { "type": "string", "minLength": 1 },
            "flowback_entry_count": { "type": "integer", "minimum": 0 }
          }
        },
        "compatibility_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "path", "status"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "minLength": 1 }
            }
          }
        },
        "updated_at": { "type": "string", "format": "date-time" },
        "updated_by": { "type": "string" }
      }
    },
    "interpretation_focus": { "type": "array", "items": { "type": "string" } },
    "open_ambiguities": { "type": "array", "items": { "type": "string" } },
    "competing_hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hypothesis_id",
          "label",
          "status",
          "summary",
          "route_kind",
          "route_target_summary",
          "route_target_ref",
          "evidence_refs",
          "evidence_ref_count",
          "exclusion_notes"
        ],
        "properties": {
          "hypothesis_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["leading", "active", "watch", "excluded"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "route_kind": {
            "type": "string",
            "enum": ["current_topic", "deferred_buffer", "followup_subtopic", "excluded"]
          },
          "route_target_summary": { "type": "string", "minLength": 1 },
          "route_target_ref": { "type": "string" },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "evidence_ref_count": { "type": "integer", "minimum": 0 },
          "exclusion_notes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "formalism_and_notation": { "type": "array", "items": { "type": "string" } },
    "observables": { "type": "array", "items": { "type": "string" } },
    "target_claims": { "type": "array", "items": { "type": "string" } },
    "deliverables": { "type": "array", "items": { "type": "string" } },
    "acceptance_tests": { "type": "array", "items": { "type": "string" } },
    "forbidden_proxies": { "type": "array", "items": { "type": "string" } },
    "uncertainty_markers": { "type": "array", "items": { "type": "string" } },
    "target_layers": {
      "type": "array",
      "items": { "type": "string", "enum": ["L1", "L2", "L3", "L4"] }
    }
  }
}
