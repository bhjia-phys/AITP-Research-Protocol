#!/usr/bin/env sh
set -eu

HOOK_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)

if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN=python3
elif command -v python >/dev/null 2>&1; then
  PYTHON_BIN=python
else
  echo "hooks/pre-commit: python3 or python is required" >&2
  exit 1
fi

exec "$PYTHON_BIN" "$HOOK_DIR/pre-commit-validate-schemas"
