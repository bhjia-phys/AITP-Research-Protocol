{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/candidate.schema.json",
  "title": "ResearchCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_type",
    "title",
    "summary",
    "topic_slug",
    "run_id",
    "origin_refs",
    "question",
    "assumptions",
    "proposed_validation_route",
    "intended_l2_targets",
    "status"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "candidate_type": {
      "type": "string",
      "enum": [
        "concept",
        "physical_picture",
        "definition_card",
        "notation_card",
        "equation_card",
        "assumption_card",
        "regime_card",
        "theorem_card",
        "claim_card",
        "proof_fragment",
        "derivation_step",
        "derivation_object",
        "method",
        "workflow",
        "topic_skill_projection",
        "bridge",
        "example_card",
        "caveat_card",
        "equivalence_map",
        "symbol_binding",
        "validation_pattern",
        "warning_note"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "origin_refs": {
      "type": "array",
      "items": {
        "$ref": "https://aitp.local/schemas/object-ref.schema.json"
      }
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposed_validation_route": {
      "type": "string",
      "minLength": 1
    },
    "intended_l2_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_validation",
        "under_validation",
        "returned_to_l3",
        "split_into_children",
        "deferred_buffered",
        "reactivated",
        "promoted",
        "auto_promoted"
      ]
    },
    "promotion_mode": {
      "type": "string",
      "enum": [
        "human",
        "ai_auto",
        "hybrid"
      ]
    },
    "promoted_units": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "split_parent_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
    },
    "split_child_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^candidate:[a-z0-9][a-z0-9-]*$"
      }
    },
    "buffer_entry_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^deferred:[a-z0-9][a-z0-9-]*$"
      }
    },
    "reactivated_from": {
      "type": "string",
      "pattern": "^deferred:[a-z0-9][a-z0-9-]*$"
    },
    "supporting_regression_question_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^regression_question:[a-z0-9][a-z0-9-]*$"
      }
    },
    "supporting_oracle_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^question_oracle:[a-z0-9][a-z0-9-]*$"
      }
    },
    "supporting_regression_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^regression_run:[a-z0-9][a-z0-9-]*$"
      }
    },
    "promotion_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "split_required": {
      "type": "boolean"
    },
    "cited_recovery_required": {
      "type": "boolean"
    },
    "followup_gap_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^open_gap:[a-z0-9][a-z0-9-]*$"
      }
    },
    "topic_completion_status": {
      "type": "string",
      "enum": [
        "not_assessed",
        "gap-aware",
        "regression-seeded",
        "regression-stable",
        "promotion-blocked",
        "promotion-ready"
      ]
    }
  }
}
