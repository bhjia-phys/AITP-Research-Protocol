{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/consultation-index-entry.schema.json",
  "title": "ConsultationIndexEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consultation_id",
    "topic_slug",
    "stage",
    "status",
    "context_ref",
    "request_path",
    "result_path",
    "application_path",
    "summary"
  ],
  "properties": {
    "consultation_id": {
      "type": "string",
      "pattern": "^consult:[a-z0-9][a-z0-9-]*$"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "enum": [
        "L1",
        "L3",
        "L4"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "requested",
        "resolved",
        "applied"
      ]
    },
    "context_ref": {
      "$ref": "https://aitp.local/schemas/object-ref.schema.json"
    },
    "request_path": {
      "type": "string",
      "minLength": 1
    },
    "result_path": {
      "type": "string",
      "minLength": 1
    },
    "application_path": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
