{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/consult-result.schema.json",
  "title": "L2ConsultResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consultation_id",
    "topic_slug",
    "stage",
    "retrieval_profile",
    "query_text",
    "retrieved_refs",
    "result_summary",
    "produced_by",
    "produced_at"
  ],
  "properties": {
    "consultation_id": {
      "type": "string",
      "pattern": "^consult:[a-z0-9][a-z0-9-]*$"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "enum": [
        "L1",
        "L3",
        "L4"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "retrieval_profile": {
      "type": "string",
      "minLength": 1
    },
    "query_text": {
      "type": "string",
      "minLength": 1
    },
    "retrieved_refs": {
      "type": "array",
      "items": {
        "$ref": "https://aitp.local/schemas/object-ref.schema.json"
      }
    },
    "expanded_edge_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "traversal_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "path_depth",
          "path",
          "path_relations",
          "path_node_ids"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "path_depth": {
            "type": "integer",
            "minimum": 1
          },
          "path": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "from_id",
                "relation",
                "to_id"
              ],
              "properties": {
                "from_id": {
                  "type": "string",
                  "minLength": 1
                },
                "relation": {
                  "type": "string",
                  "minLength": 1
                },
                "to_id": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "path_relations": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "path_node_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "retrieval_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_traversal_depth",
        "max_expanded_hits",
        "expanded_hit_count",
        "max_depth_reached",
        "edge_types_used"
      ],
      "properties": {
        "max_traversal_depth": {
          "type": "integer",
          "minimum": 0
        },
        "max_expanded_hits": {
          "type": "integer",
          "minimum": 0
        },
        "expanded_hit_count": {
          "type": "integer",
          "minimum": 0
        },
        "max_depth_reached": {
          "type": "integer",
          "minimum": 0
        },
        "edge_types_used": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "result_summary": {
      "type": "string",
      "minLength": 1
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  }
}
