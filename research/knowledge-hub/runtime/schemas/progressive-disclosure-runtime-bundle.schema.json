  "$defs": {
    "nullable_stage": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^L[0-4]$"
    },
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "trigger_name": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "decision_override_present",
            "promotion_intent",
            "non_trivial_consultation",
            "capability_gap_blocker",
            "trust_missing",
            "contradiction_detected",
            "proof_completion_review",
            "verification_route_selection"
          ]
        },
        {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      ]
    },
    "slice_name": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "current_execution_lane",
            "decision_and_queue_details",
            "consultation_memory",
            "promotion_and_writeback",
            "capability_and_skill_discovery",
            "proof_completion_and_coverage",
            "verification_route_selection"
          ]
        },
        {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      ]
    },
    "path_reason": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "deferred_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "trigger",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "$ref": "#/$defs/trigger_name"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "escalation_trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger",
        "active",
        "condition",
        "required_reads"
      ],
      "properties": {
        "trigger": {
          "$ref": "#/$defs/trigger_name"
        },
        "active": {
          "type": "boolean"
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "required_reads": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "protocol_slice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slice",
        "trigger",
        "paths"
      ],
      "properties": {
        "slice": {
          "$ref": "#/$defs/slice_name"
        },
        "trigger": {
          "oneOf": [
            {
              "const": ""
            },
            {
              "$ref": "#/$defs/trigger_name"
            }
          ]
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
