{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/followup-gap-writeback.schema.json",
  "title": "FollowupGapWriteback",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "gap_writeback_version",
    "topic_slug",
    "run_id",
    "result_id",
    "updated_at",
    "updated_by",
    "gaps"
  ],
  "properties": {
    "gap_writeback_version": {
      "type": "integer",
      "const": 1
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "result_id": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gap_id",
          "gap_kind",
          "title",
          "summary",
          "blocker_reason",
          "parent_route_id",
          "parent_task_id",
          "return_to_stage",
          "reopen_conditions",
          "evidence_refs",
          "theorem_family_ids",
          "affected_unit_ids",
          "status",
          "suggested_queries"
        ],
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^followup_gap:[a-z0-9][a-z0-9-]*$"
          },
          "gap_kind": {
            "type": "string",
            "enum": [
              "missing_definition",
              "missing_lemma",
              "missing_cited_result",
              "missing_derivation_step",
              "cross_paper_dependency",
              "formalization_blocker",
              "contradiction"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "blocker_reason": {
            "type": "string",
            "minLength": 1
          },
          "parent_route_id": {
            "type": "string",
            "minLength": 1
          },
          "parent_task_id": {
            "type": "string",
            "minLength": 1
          },
          "parent_candidate_id": {
            "type": "string"
          },
          "parent_unit_id": {
            "type": "string"
          },
          "theorem_family_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "affected_unit_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "return_to_stage": {
            "type": "string",
            "enum": [
              "L0",
              "L1",
              "L3",
              "L4_formalization"
            ]
          },
          "reopen_conditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "buffered",
              "resolved",
              "dismissed"
            ]
          },
          "suggested_queries": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "query",
                "reason",
                "priority",
                "target_source_type"
              ],
              "properties": {
                "query": {
                  "type": "string",
                  "minLength": 1
                },
                "reason": {
                  "type": "string",
                  "minLength": 1
                },
                "priority": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "target_source_type": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
