{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/result-brief.schema.json",
  "title": "AITP Result Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "kind",
    "topic_slug",
    "interaction_class",
    "what_changed",
    "evidence_summary",
    "scope_summary",
    "non_claims",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "$schema": {
      "const": "https://aitp.local/schemas/result-brief.schema.json"
    },
    "kind": {
      "type": "string",
      "const": "result_brief"
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "interaction_class": {
      "type": "string",
      "enum": [
        "free_explore",
        "silent_continue",
        "non_blocking_update",
        "checkpoint_question"
      ]
    },
    "what_changed": {
      "type": "string",
      "minLength": 1
    },
    "evidence_summary": {
      "type": "string",
      "minLength": 1
    },
    "scope_summary": {
      "type": "string",
      "minLength": 1
    },
    "non_claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    }
  }
}
