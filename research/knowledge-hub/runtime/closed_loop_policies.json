{
  "policy_version": 1,
  "route_selection": {
    "stopwords": [
      "the",
      "and",
      "for",
      "with",
      "that",
      "this",
      "from",
      "into",
      "then",
      "than",
      "when",
      "what",
      "does",
      "still",
      "full",
      "same",
      "only",
      "before",
      "after",
      "rather",
      "because",
      "whether",
      "where",
      "which",
      "current",
      "existing",
      "result",
      "results",
      "note",
      "task",
      "tasks",
      "scan"
    ],
    "min_route_token_overlap": 2,
    "min_route_score": 140,
    "non_execution_prefixes": [
      "treat ",
      "keep ",
      "use the existing",
      "use existing",
      "regard "
    ],
    "execution_hints": [
      "complete",
      "extend",
      "run ",
      "re-run",
      "rerun",
      "benchmark",
      "baseline",
      "regression",
      "scan",
      "validate",
      "check",
      "compare",
      "prepare",
      "materialize"
    ],
    "rerun_hints": [
      "re-run",
      "rerun",
      "run again",
      "repeat"
    ],
    "default_failure_signals": [
      "The declared execution result artifact is missing.",
      "The returned result overclaims beyond the recorded limitations."
    ],
    "selection_reason_templates": {
      "explicit_match": "Selected the explicitly referenced execution-task record from the current pending actions.",
      "score_match": "Selected the highest-scoring pending action against an existing non-completed execution-task record.",
      "fallback": "Selected the strongest executable validation lane from the current pending actions."
    }
  },
  "result_ingest": {
    "valid_result_statuses": [
      "success",
      "failed",
      "partial"
    ],
    "valid_decisions": [
      "keep",
      "revise",
      "discard",
      "defer"
    ],
    "decision_rules": [
      {
        "id": "fixture_backed_or_non_scientific",
        "decision": "defer",
        "reason": "Fixture-backed or explicitly non-scientific result; keep it as a control-path demonstration rather than a scientific adjudication.",
        "confidence": 0.25,
        "when_any_true": [
          "fixture_backed",
          "non_scientific"
        ]
      },
      {
        "id": "failed_or_contradicted",
        "decision": "revise",
        "reason": "Execution failed or contradicted its declared expectation, so the route should be revised before reuse.",
        "confidence": 0.5,
        "manifest_status_in": [
          "failed"
        ],
        "when_any_true": [
          "contradiction_detected"
        ]
      },
      {
        "id": "partial_or_inconclusive",
        "decision": "defer",
        "reason": "Result is partial or inconclusive, so the route stays deferred pending bounded follow-up.",
        "confidence": 0.25,
        "manifest_status_in": [
          "partial"
        ],
        "when_any_true": [
          "inconclusive",
          "missing_baseline_support"
        ]
      },
      {
        "id": "default_keep",
        "decision": "keep",
        "reason": "Returned result met the declared task contract without immediate contradiction.",
        "confidence": 0.6
      }
    ],
    "candidate_status_by_decision": {
      "keep": "ready_for_validation",
      "revise": "returned_to_l3",
      "discard": "returned_to_l3",
      "defer": "deferred_buffered"
    },
    "followup_policy": {
      "trigger_flags": [
        "needs_literature_followup",
        "inconclusive",
        "contradiction_detected",
        "missing_baseline_support"
      ],
      "trigger_decisions": [
        "defer",
        "revise"
      ],
      "default_target_source_type": "paper",
      "default_priority": "medium",
      "baseline_gap_priority": "high",
      "baseline_query_suffix": "limitation baseline comparison",
      "contradiction_query_suffix": "contradiction sector dependence",
      "contradiction_reason": "Returned result flagged a contradiction or mismatch that needs literature context.",
      "max_queries": 3
    },
    "failure_classification": {
      "default_category": "success_without_detected_failure",
      "default_severity": "info",
      "severity_rank": {
        "info": 0,
        "warning": 1,
        "error": 2
      },
      "summary_by_severity": {
        "info": "No blocking failure class was detected during ingest.",
        "warning": "The result remained bounded or incomplete and should not be treated as a clean scientific keep.",
        "error": "The result violated part of the declared task/result contract and requires explicit revision."
      },
      "category_rules": [
        {
          "id": "fixture_backed_control",
          "severity": "warning",
          "when_any_true": [
            "manifest.fixture_backed",
            "manifest.non_scientific"
          ]
        },
        {
          "id": "executor_failed",
          "severity": "error",
          "when_any_true": [
            "manifest.executor_reported_status=failed",
            "manifest.status=failed"
          ]
        },
        {
          "id": "missing_artifacts",
          "severity": "error",
          "when_any_true": [
            "missing_artifacts_present"
          ]
        },
        {
          "id": "task_contract_mismatch",
          "severity": "error",
          "when_any_true": [
            "task_contract_mismatch"
          ]
        },
        {
          "id": "contradiction_detected",
          "severity": "error",
          "when_any_true": [
            "contradiction_detected"
          ]
        },
        {
          "id": "baseline_gap",
          "severity": "warning",
          "when_any_true": [
            "missing_baseline_support"
          ]
        },
        {
          "id": "inconclusive_or_partial",
          "severity": "warning",
          "when_any_true": [
            "inconclusive",
            "manifest.status=partial"
          ]
        }
      ]
    }
  },
  "auto_promotion_policy": {
    "enabled": true,
    "default_backend_id": "backend:theoretical-physics-knowledge-network",
    "trigger_candidate_statuses": [
      "ready_for_validation",
      "reactivated",
      "returned_to_l3"
    ],
    "required_theory_packet_artifacts": [
      "structure_map",
      "coverage_ledger",
      "notation_table",
      "derivation_graph",
      "agent_consensus",
      "regression_gate"
    ],
    "require_regression_gate_pass": true,
    "block_when_split_required": true,
    "block_when_promotion_blockers_present": true,
    "block_when_cited_recovery_required": true,
    "theory_formal_candidate_types": [
      "definition_card",
      "notation_card",
      "equation_card",
      "assumption_card",
      "regime_card",
      "theorem_card",
      "proof_fragment",
      "derivation_step",
      "example_card",
      "caveat_card",
      "equivalence_map",
      "symbol_binding"
    ]
  },
  "followup_subtopic_policy": {
    "enabled": true,
    "max_subtopics_per_receipt": 2,
    "bounded_gap_required": true,
    "spawn_target_source_types": [
      "paper",
      "arxiv",
      "review"
    ],
    "return_packet_filename": "followup_return_packet.json",
    "expected_return_route": "L0->L1->L3->L4->L2",
    "acceptable_return_shapes": [
      "recovered_units",
      "resolved_gap_update",
      "still_unresolved_packet"
    ],
    "required_output_artifacts": [
      "candidate_ledger_or_recovered_units",
      "gap_or_followup_writeback",
      "reintegration_summary"
    ],
    "unresolved_return_statuses": [
      "pending_reentry",
      "returned_with_gap",
      "returned_unresolved"
    ],
    "reintegration_requirements": {
      "must_write_back_parent_gaps": true,
      "must_update_reentry_targets": true,
      "must_not_patch_parent_directly": true,
      "requires_child_topic_summary": true
    },
    "statement_template": "Follow up the cited-literature gap `{query}` from parent topic `{topic_slug}` using source `{arxiv_id}`.",
    "human_request_template": "Study the follow-up paper `{arxiv_id}` for the bounded gap `{query}` and build an independent AITP subtopic from L0 onward."
  },
  "topic_completion_policy": {
    "enabled": true
  },
  "lean_bridge_policy": {
    "enabled": true,
    "trigger_candidate_types": [
      "definition_card",
      "notation_card",
      "equation_card",
      "assumption_card",
      "regime_card",
      "theorem_card",
      "proof_fragment",
      "derivation_step",
      "equivalence_map",
      "symbol_binding"
    ]
  },
  "candidate_split_policy": {
    "enabled": true,
    "contract_filename": "candidate_split.contract.json",
    "auto_apply_contracts": true,
    "receipt_filename": "candidate_split_receipts.jsonl",
    "deferred_buffer_filename": "deferred_candidates.json"
  },
  "deferred_buffer_policy": {
    "enabled": true,
    "auto_reactivate": true,
    "status_values": [
      "buffered",
      "reactivated",
      "dismissed"
    ]
  },
  "followup_gap_policy": {
    "enabled": true,
    "default_status": "open",
    "allowed_gap_kinds": [
      "missing_definition",
      "missing_lemma",
      "missing_cited_result",
      "missing_derivation_step",
      "cross_paper_dependency",
      "formalization_blocker",
      "contradiction"
    ],
    "return_to_stage_by_kind": {
      "missing_definition": "L1",
      "missing_lemma": "L3",
      "missing_cited_result": "L0",
      "missing_derivation_step": "L3",
      "cross_paper_dependency": "L0",
      "formalization_blocker": "L4_formalization",
      "contradiction": "L3"
    },
    "default_priority_by_stage": {
      "L0": "high",
      "L1": "medium",
      "L3": "medium",
      "L4_formalization": "medium"
    },
    "default_target_source_type": "paper"
  },
  "formal_theory_trust_boundary_policy": {
    "enabled": true,
    "trusted_roles": [
      "trusted_target"
    ],
    "intermediate_roles": [
      "intermediate_theory"
    ],
    "supporting_roles": [
      "supporting_context"
    ],
    "required_unit_fields": [
      "formal_theory_role",
      "statement_graph_role",
      "statement_graph_parents",
      "statement_graph_children"
    ],
    "blocking_rule": "Do not treat intermediate theory, temporary scaffolds, or explanatory bridges as the trusted target statement."
  },
  "faithfulness_policy": {
    "enabled": true,
    "allowed_statuses": [
      "not_applicable",
      "pending",
      "bounded",
      "reviewed"
    ],
    "default_required_for_roles": [
      "trusted_target",
      "intermediate_theory"
    ],
    "blocking_statuses": [
      "pending"
    ],
    "minimum_fields": [
      "faithfulness_status",
      "faithfulness_strategy"
    ]
  },
  "comparator_audit_policy": {
    "enabled": true,
    "allowed_statuses": [
      "not_applicable",
      "pending",
      "passed",
      "failed"
    ],
    "required_for_roles": [
      "trusted_target",
      "intermediate_theory"
    ],
    "failure_blocks_promotion": true,
    "comparator_goal": "Check that the promoted or formalized statement is equivalent to the scientific source target rather than to a weakened nearby claim."
  },
  "provenance_review_policy": {
    "enabled": true,
    "allowed_provenance_kinds": [
      "source_derived",
      "retrieved_existing_formalization",
      "adapted_existing_formalization",
      "generated_from_scratch",
      "mixed"
    ],
    "minimum_fields": [
      "provenance_kind",
      "attribution_requirements"
    ],
    "missing_provenance_blocks_promotion": true
  },
  "prerequisite_closure_policy": {
    "enabled": true,
    "allowed_statuses": [
      "not_needed",
      "pending",
      "partial",
      "closed"
    ],
    "default_required_for_roles": [
      "trusted_target",
      "intermediate_theory"
    ],
    "blocking_statuses": [
      "pending",
      "partial"
    ],
    "required_support_fields": [
      "dependencies",
      "lean_prerequisite_ids",
      "supporting_obligation_ids",
      "formalization_blockers"
    ]
  },
  "benchmark_governance_policy": {
    "enabled": true,
    "allowed_contamination_statuses": [
      "clean",
      "contaminated",
      "internal-only",
      "unknown"
    ],
    "allowed_benchmark_uses": [
      "workflow_regression",
      "research_iteration",
      "external_evaluation"
    ],
    "external_claim_requires_clean_suite": true
  }
}
