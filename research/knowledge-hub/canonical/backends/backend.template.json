{
  "$schema": "../../schemas/l2-backend.schema.json",
  "backend_id": "backend:replace-me",
  "title": "Replace Me",
  "backend_type": "human_note_library",
  "status": "planned",
  "root_paths": [
    "/absolute/path/to/backend"
  ],
  "purpose": [
    "What this backend is for"
  ],
  "artifact_granularity": "State the atomic reusable unit, for example: single local note, single derivation note, single code module, or single benchmark result.",
  "source_policy": {
    "requires_l0_registration": true,
    "allows_direct_canonical_promotion": false,
    "default_source_type": "local_note"
  },
  "l0_registration": {
    "script": "source-layer/scripts/register_local_note_source.py",
    "required_provenance_fields": [
      "provenance.backend_id",
      "provenance.backend_root",
      "provenance.backend_artifact_kind"
    ],
    "required_locator_fields": [
      "locator.backend_relative_path"
    ]
  },
  "canonical_targets": [
    "concept"
  ],
  "retrieval_hints": [
    "How AITP should consult this backend"
  ],
  "notes": "One short note about why this backend exists."
}
