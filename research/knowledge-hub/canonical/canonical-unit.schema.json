{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/canonical-unit.schema.json",
  "title": "CanonicalUnit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "unit_type",
    "title",
    "summary",
    "maturity",
    "created_at",
    "updated_at",
    "topic_completion_status",
    "tags",
    "assumptions",
    "regime",
    "scope",
    "provenance",
    "promotion",
    "dependencies",
    "related_units",
    "payload"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
    },
    "unit_type": {
      "type": "string",
      "enum": [
        "atomic_note",
        "concept",
        "physical_picture",
        "definition_card",
        "notation_card",
        "equation_card",
        "assumption_card",
        "regime_card",
        "theorem_card",
        "claim_card",
        "proof_fragment",
        "derivation_step",
        "derivation_object",
        "method",
        "workflow",
        "topic_skill_projection",
        "bridge",
        "example_card",
        "caveat_card",
        "equivalence_map",
        "symbol_binding",
        "validation_pattern",
        "warning_note",
        "negative_result"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "topic_completion_status": {
      "type": "string",
      "enum": [
        "not_assessed",
        "gap-aware",
        "regression-seeded",
        "regression-stable",
        "promotion-blocked",
        "promotion-ready"
      ]
    },
    "maturity": {
      "type": "string",
      "enum": [
        "draft",
        "candidate",
        "validated",
        "stable",
        "deprecated",
        "auto_candidate",
        "auto_validated",
        "cross_paper_stable",
        "human_promoted"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "regime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "approximations",
        "scale",
        "boundary_conditions",
        "exclusions"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "approximations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scale": {
          "type": "string"
        },
        "boundary_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclusions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applies_to",
        "out_of_scope"
      ],
      "properties": {
        "applies_to": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ids",
        "l1_artifacts",
        "l3_runs",
        "l4_checks",
        "citations"
      ],
      "properties": {
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "backend_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^backend:[a-z0-9][a-z0-9-]*$"
          }
        },
        "l1_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "l3_runs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "l4_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "citations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "promoted_by",
        "promoted_at",
        "review_status",
        "rationale"
      ],
      "properties": {
        "route": {
          "type": "string",
          "enum": [
            "L1->L2",
            "L3->L4->L2",
            "L1->L2_auto",
            "L3->L4_auto->L2_auto",
            "L2_auto->L2"
          ]
        },
        "review_mode": {
          "type": "string",
          "enum": [
            "human",
            "ai_auto",
            "hybrid"
          ]
        },
        "canonical_layer": {
          "type": "string",
          "enum": [
            "L2",
            "L2_auto"
          ]
        },
        "coverage_status": {
          "type": "string"
        },
        "consensus_status": {
          "type": "string"
        },
        "regression_gate_status": {
          "type": "string"
        },
        "supporting_regression_question_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^regression_question:[a-z0-9][a-z0-9-]*$"
          }
        },
        "supporting_oracle_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^question_oracle:[a-z0-9][a-z0-9-]*$"
          }
        },
        "supporting_regression_run_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^regression_run:[a-z0-9][a-z0-9-]*$"
          }
        },
        "promotion_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cited_recovery_required": {
          "type": "boolean"
        },
        "followup_gap_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^open_gap:[a-z0-9][a-z0-9-]*$"
          }
        },
        "split_clearance_status": {
          "type": "string",
          "enum": [
            "clear",
            "blocked",
            "not_applicable"
          ]
        },
        "promotion_blockers_cleared": {
          "type": "boolean"
        },
        "promoted_by": {
          "type": "string"
        },
        "promoted_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_status": {
          "type": "string",
          "enum": [
            "accepted",
            "deferred",
            "rejected",
            "needs_revision"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "origin_topic_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "origin_run_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_receipts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reuse_receipts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_consultation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applicable_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "regime_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_units": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
