{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/l2-backend.schema.json",
  "title": "L2Backend",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "backend_id",
    "title",
    "backend_type",
    "status",
    "root_paths",
    "purpose",
    "artifact_granularity",
    "source_policy",
    "l0_registration",
    "canonical_targets",
    "retrieval_hints",
    "notes"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "backend_id": {
      "type": "string",
      "pattern": "^backend:[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "backend_type": {
      "type": "string",
      "enum": [
        "human_note_library",
        "software_repo",
        "local_docs_repo",
        "local_result_store",
        "mixed_local_library"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "planned",
        "deprecated"
      ]
    },
    "root_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "purpose": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_granularity": {
      "type": "string",
      "minLength": 1
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_l0_registration",
        "allows_direct_canonical_promotion",
        "allows_auto_canonical_promotion",
        "auto_promotion_domains",
        "auto_promotion_requires_coverage_audit",
        "auto_promotion_requires_multi_agent_consensus",
        "auto_promotion_requires_regression_gate",
        "auto_promotion_requires_split_clearance",
        "auto_promotion_requires_gap_honesty",
        "default_source_type"
      ],
      "properties": {
        "requires_l0_registration": {
          "type": "boolean"
        },
        "allows_direct_canonical_promotion": {
          "type": "boolean"
        },
        "allows_auto_canonical_promotion": {
          "type": "boolean"
        },
        "auto_promotion_domains": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "auto_promotion_requires_coverage_audit": {
          "type": "boolean"
        },
        "auto_promotion_requires_multi_agent_consensus": {
          "type": "boolean"
        },
        "auto_promotion_requires_regression_gate": {
          "type": "boolean"
        },
        "auto_promotion_requires_split_clearance": {
          "type": "boolean"
        },
        "auto_promotion_requires_gap_honesty": {
          "type": "boolean"
        },
        "default_source_type": {
          "type": "string",
          "enum": [
            "paper",
            "pdf",
            "url",
            "web_page",
            "video",
            "transcript",
            "conversation",
            "local_note"
          ]
        }
      }
    },
    "l0_registration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script",
        "required_provenance_fields",
        "required_locator_fields"
      ],
      "properties": {
        "script": {
          "type": "string",
          "minLength": 1
        },
        "required_provenance_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_locator_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "canonical_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "atomic_note",
          "concept",
          "physical_picture",
          "definition_card",
          "notation_card",
          "equation_card",
          "assumption_card",
          "regime_card",
          "theorem_card",
          "claim_card",
          "proof_fragment",
          "derivation_step",
          "derivation_object",
          "method",
          "workflow",
          "topic_skill_projection",
          "bridge",
          "example_card",
          "caveat_card",
          "equivalence_map",
          "symbol_binding",
          "validation_pattern",
          "warning_note",
          "negative_result"
        ]
      }
    },
    "retrieval_hints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  }
}
