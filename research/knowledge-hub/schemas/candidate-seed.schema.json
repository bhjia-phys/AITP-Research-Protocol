{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/candidate-seed.schema.json",
  "title": "CandidateSeed",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_seed_id",
    "source_refs",
    "claim_refs",
    "question",
    "proposed_candidate_type",
    "reason_for_escalation"
  ],
  "properties": {
    "candidate_seed_id": {
      "type": "string",
      "pattern": "^candidate_seed:[a-z0-9][a-z0-9-]*$"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "https://aitp.local/schemas/object-ref.schema.json"
      }
    },
    "claim_refs": {
      "type": "array",
      "items": {
        "$ref": "https://aitp.local/schemas/object-ref.schema.json"
      }
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "proposed_candidate_type": {
      "type": "string",
      "minLength": 1
    },
    "reason_for_escalation": {
      "type": "string",
      "minLength": 1
    }
  }
}
