{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/proof-repair-plan.schema.json",
  "title": "AITP Proof Repair Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "plan_version",
    "topic_slug",
    "run_id",
    "candidate_id",
    "status",
    "compilation_path",
    "repair_stages",
    "proof_holes",
    "downstream_targets",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "$schema": {
      "const": "https://aitp.local/schemas/proof-repair-plan.schema.json"
    },
    "plan_version": {
      "const": 1
    },
    "topic_slug": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "needs_repair"
      ]
    },
    "compilation_path": {
      "type": "string",
      "minLength": 1
    },
    "repair_stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_id",
          "stage_name",
          "status",
          "summary"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "minLength": 1
          },
          "stage_name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "proof_holes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hole_id",
          "category",
          "status",
          "claim",
          "source_anchor_ids",
          "required_artifacts",
          "verifier_targets",
          "close_condition"
        ],
        "properties": {
          "hole_id": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "source_anchor_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verifier_targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "close_condition": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "downstream_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assistant",
          "kind",
          "status",
          "reason"
        ],
        "properties": {
          "assistant": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string",
      "minLength": 1
    }
  }
}
