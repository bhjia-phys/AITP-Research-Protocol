{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/edge.schema.json",
  "title": "L2Edge",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edge_id",
    "from_id",
    "relation",
    "to_id",
    "evidence_refs",
    "notes"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "from_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
    },
    "relation": {
      "type": "string",
      "enum": [
        "depends_on",
        "supports",
        "contradicts",
        "specializes",
        "generalizes",
        "uses_method",
        "validated_by",
        "warned_by",
        "bridged_to",
        "derived_from",
        "applies_in_regime"
      ]
    },
    "to_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
