{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/l2-staging-entry.schema.json",
  "title": "L2StagingEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entry_id",
    "title",
    "summary",
    "candidate_unit_type",
    "trust_surface",
    "status",
    "tags",
    "source_refs",
    "created_at",
    "updated_at",
    "created_by"
  ],
  "properties": {
    "entry_id": {
      "type": "string",
      "pattern": "^staging:[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "candidate_unit_type": {
      "type": "string",
      "enum": [
        "atomic_note",
        "concept",
        "physical_picture",
        "claim_card",
        "method",
        "workflow",
        "topic_skill_projection",
        "bridge",
        "example_card",
        "validation_pattern",
        "warning_note",
        "negative_result"
      ]
    },
    "trust_surface": {
      "type": "string",
      "const": "staging"
    },
    "status": {
      "type": "string",
      "enum": [
        "staged",
        "promoted",
        "rejected"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "linked_unit_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "contradicts_unit_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*:[a-z0-9][a-z0-9-]*$"
      }
    },
    "integration_summary": {
      "type": "string"
    },
    "failure_kind": {
      "type": "string"
    },
    "failed_route": {
      "type": "string"
    },
    "next_implication": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope_note": {
      "type": "string"
    },
    "topic_slug": {
      "type": "string"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "literature_intake_fast_path": {
          "type": "boolean"
        },
        "source_id": {
          "type": "string"
        },
        "source_title": {
          "type": "string"
        },
        "source_slug": {
          "type": "string"
        },
        "literature_stage_signature": {
          "type": "string"
        },
        "vault_wiki_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "graph_analysis_kind": {
          "type": "string"
        },
        "question_type": {
          "type": "string"
        },
        "bridge_label": {
          "type": "string"
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "community_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}
