{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromotionOrRejectContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "topic_slug",
    "target_ids",
    "status",
    "decision",
    "reason",
    "destination_layer",
    "follow_up_actions"
  ],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "topic_slug": { "type": "string", "minLength": 1 },
    "target_ids": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["draft", "issued", "superseded"] },
    "decision": { "type": "string", "enum": ["promote", "revise", "reject", "defer"] },
    "reason": { "type": "string", "minLength": 1 },
    "destination_layer": { "type": "string", "enum": ["L1", "L2", "L3", "L4", "none"] },
    "follow_up_actions": { "type": "array", "items": { "type": "string" } }
  }
}
