{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aitp.local/schemas/object-ref.schema.json",
  "title": "ObjectRef",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "layer",
    "object_type",
    "path",
    "title",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "layer": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "object_type": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
