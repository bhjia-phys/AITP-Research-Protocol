{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON_EXE}}\" \"{{AITP_HOOKS_DIR}}/aitp-keyword-router.py\"",
            "async": false
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON_EXE}}\" \"{{AITP_HOOKS_DIR}}/aitp-routing-guard.py\"",
            "async": false
          }
        ]
      }
    ]
  }
}
